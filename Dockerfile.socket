# Minimal Socket.IO + Redis adapter gateway (separate from Next HTTP server).
FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production
COPY package.json package-lock.json* ./
RUN npm install --omit=dev --ignore-scripts --no-audit --no-fund
COPY realtime/socket-server.mjs ./realtime/
ENV REDIS_URL=redis://redis:6379
EXPOSE 3002
CMD ["node", "realtime/socket-server.mjs"]
